# Node modules — rebuilt inside container
node_modules/

# Prisma generated client — regenerated during build
generated/

# Local env file — values injected by Docker at runtime
.env

# Deno cache
.deno/

# Logs and runtime files
*.log
*.pid

# Most scripts are not needed at runtime. Keep only runtime database/bootstrap
# scripts plus backup scripts used by the dedicated backup service image.
scripts/*
!scripts/seed.ts
!scripts/import_pir_demo_from_csv.ts
!scripts/migrate_trimesters_to_quarters.ts
!scripts/migrate_focal_persons.ts
!scripts/backup/
!scripts/backup/**
!scripts/db_init_backup_user.sh
!scripts/db_readonly_user.sql
