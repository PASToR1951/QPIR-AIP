{
  "nodeModulesDir": "manual",
  "tasks": {
    "prisma:deploy": "npx prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:generate": "npx prisma generate --schema prisma/schema.prisma",
    "prisma:prepare": "deno task prisma:deploy && deno task prisma:generate",
    "start": "deno task prisma:prepare && deno run --env --allow-net --allow-env --allow-read --allow-write --allow-sys server.ts",
    "dev": "deno run --watch --env --allow-net --allow-env --allow-read --allow-write --allow-sys server.ts",
    "tunnel": "deno run --watch --env-file=.env.tunnel --allow-net --allow-env --allow-read --allow-write --allow-sys server.ts",
    "seed": "deno run -A --env scripts/seed.ts"
  },
  "imports": {
    "@prisma/config": "npm:@prisma/config@^7.4.2",
    "hono": "npm:hono@^4.0.0",
    "@prisma/client": "npm:@prisma/client@^7.4.2",
    "bcrypt": "npm:bcryptjs@^2.4.3",
    "jsonwebtoken": "npm:jsonwebtoken@^9.0.3"
  },
  "allowScripts": {
    "allow": [],
    "deny": ["npm:@prisma/engines@7.4.2", "npm:prisma@7.4.2"]
  }
}
