// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Division {
  SGOD
  OSDS
  CID
}


model Cluster {
  id             Int      @id @default(autoincrement())
  cluster_number Int      @unique
  name           String
  logo           String?  // Uploaded cluster logo path. Null = use bundled cluster logo.

  // Relations
  schools           School[]
  coordinator_users User[]   @relation("UserCluster")

  // Admin-designated cluster head (one-to-one)
  cluster_head_id   Int?     @unique
  cluster_head      User?    @relation("ClusterHead", fields: [cluster_head_id], references: [id], onDelete: SetNull)

  @@map("clusters")
}

model School {
  id           Int     @id @default(autoincrement())
  name         String
  abbreviation String? // Short name / acronym, e.g. "SNES"
  level        String  // "Elementary", "Secondary"
  cluster_id   Int
  logo         String? // Uploaded school logo path. Null = use cluster logo.
  
  // Relations
  cluster    Cluster  @relation(fields: [cluster_id], references: [id], onDelete: Cascade)
  aips       AIP[]
  users      User[]
  restricted_programs      Program[]                   @relation("RestrictedPrograms")
  announcement_mentions    AnnouncementMentionSchool[]

  @@map("schools")
}


model Program {
  id                       Int     @id @default(autoincrement())
  title                    String
  abbreviation             String? // Short name / acronym, e.g. "SPED"
  division                 Division? // "SGOD" | "OSDS" | "CID" — determines CES routing for Division Personnel PIRs
  school_level_requirement String  // "Elementary", "Secondary", "Both", "Select Schools", "Division"

  // Relations
  aips                     AIP[]
  template                 ProgramTemplate?
  personnel                User[] @relation("UserPrograms")
  restricted_schools       School[] @relation("RestrictedPrograms")

  @@unique([title, school_level_requirement])
  @@map("programs")
}

model ProgramTemplate {
  id                 Int      @id @default(autoincrement())
  program_id         Int      @unique
  outcome            String
  target_code        String
  target_description String
  indicators         Json     @default("[]")
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  program            Program  @relation(fields: [program_id], references: [id], onDelete: Cascade)

  @@map("program_templates")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String?   // Hashed password — null for OAuth-only users
  role            String    // "School" | "Division Personnel" | "Admin" | "CES-SGOD" | "CES-ASDS" | "CES-CID" | "Cluster Coordinator" | "Pending" | "Observer"

  // OAuth SSO fields — populated on first OAuth login
  oauth_provider  String?   // "google" | null
  oauth_subject   String?   // Immutable IdP user ID (sub for Google)
  salutation      String?   // "Mr." | "Ms." | "Mrs." | "Dr."
  name            String?
  first_name      String?
  middle_initial  String?
  last_name       String?
  position        String?   // Job title / position e.g. "Education Program Supervisor I"
  is_active             Boolean   @default(true)
  must_change_password  Boolean   @default(false) // Set to true when admin resets password — forces change on next login
  deleted_at      DateTime? // Soft-delete timestamp — RA 10173 §19 retention support
  onboarding_version_seen  Int       @default(0)
  onboarding_show_on_login Boolean   @default(true)
  onboarding_dismissed_at  DateTime?
  onboarding_completed_at  DateTime?
  checklist_progress       Json      @default("{}")

  // Relation to School (For School Role Users)
  school_id  Int?
  school     School?  @relation(fields: [school_id], references: [id])

  // Relation to Cluster (For Cluster Coordinator users)
  cluster_id Int?
  cluster    Cluster? @relation("UserCluster", fields: [cluster_id], references: [id], onDelete: SetNull)

  // Relation to Programs (For Division Personnel Users)
  programs  Program[] @relation("UserPrograms")

  // Documents created by this user (for Division Personnel tracking)
  aips      AIP[]     @relation("CreatedByUser")
  pirs      PIR[]     @relation("CreatedByUser")

  // PIRs this user CES-noted
  ces_reviewed_pirs PIR[] @relation("PIRCESReviewer")

  // PIRs this user is currently actively reviewing
  active_pir_reviews PIR[] @relation("PIRActiveReviewer")

  // Cluster this user heads (one-to-one inverse)
  headed_cluster Cluster? @relation("ClusterHead")

  // Admin audit logs
  audit_logs    AuditLog[]

  // User activity logs
  activity_logs UserActivityLog[] @relation("UserActivityLogs")

  // Authenticated browser/device sessions
  sessions      UserSession[]

  // Notifications
  notifications         Notification[]
  announcement_mentions AnnouncementMentionUser[]
  magic_link_tokens     MagicLinkToken[]
  email_blast_logs      EmailBlastLog[]

  created_at DateTime @default(now())

  @@unique([oauth_provider, oauth_subject])
}

model UserSession {
  id            Int      @id @default(autoincrement())
  user_id       Int
  session_token String   @unique
  user_agent    String?
  ip_address    String?
  device_label  String?
  created_at    DateTime @default(now())
  last_seen_at  DateTime @default(now())
  expires_at    DateTime
  revoked_at    DateTime?
  revoked_by    Int?

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at(sort: Desc)])
  @@index([expires_at])
  @@map("user_sessions")
}

// PKCE + CSRF state for OAuth flows — single-use, 10-minute TTL
model OAuthState {
  id            String   @id @default(cuid())
  nonce         String   @unique
  provider      String
  hmac          String
  code_verifier String
  expires_at    DateTime
  created_at    DateTime @default(now())

  @@map("oauth_states")
}

model AIP {
  id                  Int      @id @default(autoincrement())
  school_id           Int?     // Nullable — Division Personnel AIPs have no school
  program_id          Int
  created_by_user_id  Int?     // Nullable for backward-compat; set on all new records
  year                Int      // e.g., 2026
  outcome             String   // DepEd Outcome Category
  target_description  String   @default("")
  sip_title           String   // School Improvement Project title
  project_coordinator String
  objectives          Json     // Array of objective strings
  indicators          Json     // Array of { description, target } objects
  prepared_by_name    String   @default("")
  prepared_by_title   String   @default("")
  approved_by_name    String   @default("")
  approved_by_title   String   @default("")
  status              String   @default("Approved") // "Draft" | "Approved" | "Returned"
  edit_requested      Boolean  @default(false)       // true while user is waiting for admin to unlock
  edit_requested_at   DateTime?                     // when the last edit request was sent
  edit_request_count  Int      @default(0)          // lifetime count of edit requests (max 3)
  observer_notes      String?
  archived            Boolean  @default(false)
  archived_at         DateTime?
  deleted_at          DateTime? // Soft-delete timestamp — RA 10173 §19 retention support
  created_at          DateTime @default(now())

  // Relations
  school              School?        @relation(fields: [school_id], references: [id], onDelete: Cascade)
  program             Program        @relation(fields: [program_id], references: [id])
  created_by          User?          @relation("CreatedByUser", fields: [created_by_user_id], references: [id], onDelete: Cascade)
  activities          AIPActivity[]
  pirs                PIR[]

  @@unique([school_id, program_id, year]) // School Users: unique per school/program/year
  // Division Personnel uniqueness enforced via partial index in DB: (created_by_user_id, program_id, year) WHERE school_id IS NULL
}

model AIPActivity {
  id                    Int      @id @default(autoincrement())
  aip_id                Int
  phase                 String   // "Planning", "Implementation", "Monitoring and Evaluation"
  activity_name         String
  implementation_period String
  period_start_month    Int?     // 1=Jan … 12=Dec — nullable for legacy data
  period_end_month      Int?     // 1=Jan … 12=Dec
  persons_involved      String
  outputs               String
  budget_amount         Decimal  @default(0.0)
  budget_source         String

  // Relations
  aip                   AIP                @relation(fields: [aip_id], references: [id], onDelete: Cascade)
  pir_reviews           PIRActivityReview[]
}

model PIR {
  id                          Int      @id @default(autoincrement())
  aip_id                      Int
  created_by_user_id          Int?     // Nullable for backward-compat; set on all new records
  quarter                     String   // "1st Quarter CY 2026", etc.
  program_owner               String
  budget_from_division        Decimal  @default(0.0)
  budget_from_co_psf          Decimal  @default(0.0)
  functional_division         String?  // "SGOD" | "OSDS" | "CID" — null for school users
  indicator_quarterly_targets Json     @default("[]")
  // Shape: [{description: string, annual_target: string, quarterly_target: string}]
  action_items                Json     @default("[]")
  // Shape: [{action: string, response_asds: string, response_sds: string}]
  status                      String   @default("For CES Review") // "Draft" | "For CES Review" | "For Cluster Head Review" | "Under Review" | "Approved" | "Returned"
  deleted_at                  DateTime? // Soft-delete timestamp — RA 10173 §19 retention support
  remarks                     String?  // Admin remarks/annotations on this PIR
  observer_notes              String?
  presented                   Boolean  @default(false) // Admin-toggled: whether school presented this PIR
  // CES review tracking
  ces_reviewer_id             Int?
  ces_noted_at                DateTime?
  ces_remarks                 String?  // CES notes/feedback
  // Active review tracking — set when a reviewer opens the PIR; cleared on note/return
  active_reviewer_id          Int?
  active_review_started_at    DateTime?
  created_at                  DateTime @default(now())

  // Relations
  aip                AIP                 @relation(fields: [aip_id], references: [id], onDelete: Cascade)
  created_by         User?               @relation("CreatedByUser", fields: [created_by_user_id], references: [id], onDelete: Cascade)
  ces_reviewer       User?               @relation("PIRCESReviewer", fields: [ces_reviewer_id], references: [id], onDelete: SetNull)
  active_reviewer    User?               @relation("PIRActiveReviewer", fields: [active_reviewer_id], references: [id], onDelete: SetNull)
  activity_reviews   PIRActivityReview[]
  factors            PIRFactor[]

  @@unique([aip_id, quarter]) // Ensures only one PIR per quarter for a specific AIP
}

model PIRActivityReview {
  id                                   Int      @id @default(autoincrement())
  pir_id                               Int
  aip_activity_id                      Int?     // Nullable for unplanned activities
  complied                             Boolean? // null=unplanned activity; true=✓, false=✗
  actual_tasks_conducted               String   @default("")
  contributory_performance_indicators  String   @default("")
  movs_expected_outputs                String   @default("")
  adjustments                          String   @default("")
  is_unplanned                         Boolean  @default(false)
  physical_target                      Decimal  @default(0.0)
  financial_target                     Decimal  @default(0.0)
  physical_accomplished                Decimal  @default(0.0)
  financial_accomplished               Decimal  @default(0.0)
  actions_to_address_gap               String?
  admin_notes                          String?  // Admin per-activity evaluation notes

  // Relations
  pir                    PIR          @relation(fields: [pir_id], references: [id], onDelete: Cascade)
  aip_activity           AIPActivity? @relation(fields: [aip_activity_id], references: [id], onDelete: Cascade)

  @@unique([pir_id, aip_activity_id]) // Ensure a planned activity is reviewed only once per PIR (NULLs allowed for unplanned)
}

model PIRFactor {
  id                   Int    @id @default(autoincrement())
  pir_id               Int
  factor_type          String // "Institutional", "Technical", "Infrastructure", "Learning Resources", "Environmental", "Others"
  facilitating_factors String
  hindering_factors    String
  recommendations      String @default("")

  // Relations
  pir                  PIR    @relation(fields: [pir_id], references: [id], onDelete: Cascade)

  @@unique([pir_id, factor_type]) // Only one record per factor type per PIR
}

model Notification {
  id          Int      @id @default(autoincrement())
  user_id     Int
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  title       String
  message     String
  type        String   // "approved" | "returned" | "remarked" | "under_review"
  entity_id   Int?     // ID of the related PIR, AIP, or Announcement
  entity_type String?  // "pir" | "aip" | "announcement"
  read        Boolean  @default(false)
  created_at  DateTime @default(now())

  @@map("notifications")
}

model Deadline {
  id                 Int       @id @default(autoincrement())
  year               Int       // Fiscal year, e.g. 2026
  quarter            Int       // 1, 2, 3, or 4
  date               DateTime  // Admin-set deadline (overrides calendar default)
  open_date          DateTime? // When submissions open (null = start of quarter)
  grace_period_days  Int       @default(0) // Days after deadline still allowed
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  @@unique([year, quarter])
  @@map("deadlines")
}

model EmailConfig {
  id                     Int      @id @default(autoincrement())
  smtp_host              String   @default("smtp.gmail.com")
  smtp_port              Int      @default(587)
  smtp_user              String   @default("")
  smtp_pass_enc          String   @default("")
  from_name              String   @default("AIP-PIR System")
  is_enabled             Boolean  @default(false)
  magic_link_ttl_login   Int      @default(15)
  magic_link_ttl_welcome Int      @default(10080)
  magic_link_ttl_reminder Int     @default(1440)
  updated_at             DateTime @updatedAt

  @@map("email_config")
}

model MagicLinkToken {
  id         String   @id @default(cuid())
  user_id    Int
  token_hash String   @unique
  purpose    String   @default("login")
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([expires_at])
  @@index([user_id, purpose])
  @@map("magic_link_tokens")
}

model EmailBlastLog {
  id         Int      @id @default(autoincrement())
  blast_key  String
  blast_type String
  blast_label String
  user_id    Int
  sent_at    DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([blast_key, user_id])
  @@index([sent_at])
  @@map("email_blast_logs")
}

model Announcement {
  id          Int       @id @default(autoincrement())
  message     String
  type        String    @default("info") // "info" | "warning" | "critical"
  is_active   Boolean   @default(true)
  dismissible Boolean   @default(true)
  expires_at  DateTime?                  // null = never expires; set for auto-expiring announcements
  created_by  Int
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  // Mention targeting — empty = visible to everyone
  mentioned_schools AnnouncementMentionSchool[]
  mentioned_users   AnnouncementMentionUser[]

  @@map("announcements")
}

// Junction: announcement → schools (all users of that school can see it)
model AnnouncementMentionSchool {
  announcement_id Int
  school_id       Int
  announcement    Announcement @relation(fields: [announcement_id], references: [id], onDelete: Cascade)
  school          School       @relation(fields: [school_id], references: [id], onDelete: Cascade)

  @@id([announcement_id, school_id])
  @@map("announcement_mention_schools")
}

// Junction: announcement → division personnel users (direct mention)
model AnnouncementMentionUser {
  announcement_id Int
  user_id         Int
  announcement    Announcement @relation(fields: [announcement_id], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([announcement_id, user_id])
  @@map("announcement_mention_users")
}

model DivisionConfig {
  id               Int      @id @default(autoincrement())
  supervisor_name  String   @default("")
  supervisor_title String   @default("")
  app_logo         String?  // null = use default; "/app-logo/logo.{ext}?v=..." when set by Admin

  // Division-specific "Noted by" signatories (admin-configured)
  sgod_noted_by_name   String @default("")
  sgod_noted_by_title  String @default("")
  cid_noted_by_name    String @default("")
  cid_noted_by_title   String @default("")
  osds_noted_by_name   String @default("")
  osds_noted_by_title  String @default("")

  updated_at       DateTime @updatedAt

  @@map("division_config")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  admin_id    Int?     // Nullable — set to NULL when the acting user's account is deleted (evidence preservation)
  action      String   // e.g. "created_user", "approved_aip", "changed_deadline"
  entity_type String   // "User", "AIP", "PIR", "School", "Program", etc.
  entity_id   Int
  details     Json
  ip_address  String?  // Client IP when the log was written from an HTTP request
  created_at  DateTime @default(now())

  // SetNull preserves the audit record when the admin account is deleted (evidence retention).
  admin       User?    @relation(fields: [admin_id], references: [id], onDelete: SetNull)

  @@index([created_at(sort: Desc)])
  @@index([action, created_at(sort: Desc)])
  @@index([entity_type, entity_id, created_at(sort: Desc)])
  @@index([admin_id, created_at(sort: Desc)])
  @@map("audit_logs")
}

model UserActivityLog {
  id          Int      @id @default(autoincrement())
  user_id     Int?     // Nullable — preserved when user is deleted (evidence retention per RA 10173)
  action      String   // "login", "logout", "password_change", "aip_submit", "pir_delete", etc.
  entity_type String?  // "AIP", "PIR", null for auth events
  entity_id   Int?     // FK to the entity, null for auth events
  details     Json     @default("{}")
  ip_address  String?  // Client IP from proxy headers
  created_at  DateTime @default(now())

  user        User?    @relation("UserActivityLogs", fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id, created_at(sort: Desc)])
  @@index([created_at(sort: Desc)])
  @@index([action, created_at(sort: Desc)])
  @@index([entity_type, entity_id, created_at(sort: Desc)])
  @@map("user_activity_logs")
}
