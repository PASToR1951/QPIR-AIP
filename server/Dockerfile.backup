FROM alpine:3.20

# Install: PostgreSQL 16 client tools (pg_dump, pg_restore, psql),
#          rclone (cloud sync), openssl (encryption), dcron (cron daemon),
#          bash (scripts), curl (health checks)
RUN apk add --no-cache \
    postgresql16-client \
    rclone \
    openssl \
    dcron \
    bash \
    curl

# Copy backup scripts into the image
COPY scripts/backup/ /app/scripts/backup/

# Install crontab for root user
COPY scripts/backup/crontab /etc/crontabs/root

# Make all scripts executable
RUN chmod +x /app/scripts/backup/*.sh

# Backup data lives on a mounted volume — not baked into the image
VOLUME ["/app/backups"]

WORKDIR /app

ENTRYPOINT ["/app/scripts/backup/entrypoint.sh"]
