# AIP-PIR Docker deployment template.
# Copy this file to .env, then replace every change-me value before deploying.

# PostgreSQL
POSTGRES_USER=qpir_admin
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=pir_system
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432

# Backend publishing
BACKEND_BIND_ADDRESS=127.0.0.1
BACKEND_PORT=3001

# Frontend publishing
# Direct HTTP: FRONTEND_PORT=80
# SSL/Caddy profile: FRONTEND_PORT=127.0.0.1:8080
FRONTEND_PORT=80

# Browser-facing URLs
# Direct HTTP example:
#   ALLOWED_ORIGIN=http://203.0.113.10
#   VITE_API_URL=http://203.0.113.10:3001
# SSL/Caddy example:
#   ALLOWED_ORIGIN=https://aip-pir.example.edu
#   VITE_API_URL=https://aip-pir.example.edu
ALLOWED_ORIGIN=http://localhost
VITE_API_URL=http://localhost:3001

# Required application secrets
JWT_SECRET=change-me-jwt-secret
EMAIL_CONFIG_SECRET=change-me-email-config-secret

# Optional OAuth / reCAPTCHA
OAUTH_REDIRECT_BASE_URL=http://localhost:3001
OAUTH_STATE_SECRET=change-me-oauth-state-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RECAPTCHA_SECRET_KEY=
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_BYPASS_PRIVATE_IPS=false

# Reverse proxy settings
TRUST_PROXY=false
TRUSTED_PROXY_CIDRS=
APP_DOMAIN=aip-pir.example.edu
HTTP_BIND_ADDRESS=0.0.0.0
HTTPS_BIND_ADDRESS=0.0.0.0

# Initial seed admin. Leave SEED_ADMIN_PASSWORD empty to skip admin bootstrap in production.
SEED_ADMIN_EMAIL=admin@qpir.local
SEED_ADMIN_PASSWORD=
SEED_ADMIN_MUST_CHANGE_PASSWORD=true

# Backups
BACKUP_DB_USER=backup_reader
BACKUP_DB_PASSWORD=change-me-backup-db-password
BACKUP_ENCRYPTION_KEY=change-me-64-hex-character-backup-key
BACKUP_RETENTION_DAYS=14
BACKUP_CLOUD_ENABLED=false
BACKUP_RCLONE_REMOTE=my_remote
BACKUP_RCLONE_PATH=/AIP-PIR-Backups
RCLONE_CONFIG_DIR=./.docker/rclone
