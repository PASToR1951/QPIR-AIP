import React, { useState } from 'react';
import { 
  Plus, Trash2, Printer, ArrowRight, ArrowLeft, CheckCircle2, 
  Edit3, Calendar, Hash, BookOpen, Briefcase, User, 
  Target, FileText, Users, DollarSign, ListTodo
} from 'lucide-react';

export default function App() {
  const [currentStep, setCurrentStep] = useState(1);
  const totalSteps = 5;

  const OUTCOME_OPTIONS = [
    "Outcome 1: High Performing Teachers",
    "Outcome 2: Learners’ Physical and Mental Well-Being Protected",
    "Outcome 3: Efficient and Supportive Governance Structure",
    "Outcome 4: Improved Education Quality through Upgraded Curriculum, Modernized Assessment, and Digitally Enabled Schools",
    "Outcome 5: Empowered Graduates fit for Employment, Entrepreneurship or Higher Education"
  ];

  const [formData, setFormData] = useState({
    year: "2026",
    outcome: "Outcome 1: High Performing Teachers",
    depEdProgram: "Learning Action Cells (LAC)",
    projectTitle: "GROW (Guided Reflection and Outcome-based Work through LAC)",
    projectCoord: "DONNA P. OLILA",
    objectives: [
      "To conduct monthly LAC sessions",
      "To ensure that teachers apply Job-Embedded Learning (JEL) in classroom delivery"
    ],
    indicators: [
      { description: "Percentage of teachers with JEL implementation based on LAC sessions attended", target: "100.00%" },
      { description: "Percentage of teachers who participated in LAC sessions conducted at least once every quarter", target: "100.00%" }
    ],
    activities: [
      { phase: "Pre-Implementation", description: "Conduct LAC needs assessment and finalize the quarterly LAC implementation plan.", period: "January to December 2026", persons: "School Heads, Teachers, school personnel", outputs: "Approved LAC Implementation Plan", budgetAmount: "", budgetSource: "" },
      { phase: "Implementation", description: "Conduct quarterly LAC sessions focused on Job-Embedded Learning (JEL) strategies.", period: "January to December 2026", persons: "School Heads, Teachers, school personnel", outputs: "Attendance Sheets of LAC Sessions", budgetAmount: "", budgetSource: "" }
    ],
    preparedByName: "DONNA P. OLILA",
    preparedByTitle: "School Principal I",
    approvedByName: "DONNA P. OLILA",
    approvedByTitle: "School Principal I"
  });

  const handleTextChange = (e) => {
    const { name, value } = e.target;
    setFormData(prev => ({ ...prev, [name]: value }));
  };

  const handleObjectiveChange = (index, value) => {
    const newObjectives = [...formData.objectives];
    newObjectives[index] = value;
    setFormData(prev => ({ ...prev, objectives: newObjectives }));
  };
  const addObjective = () => setFormData(prev => ({ ...prev, objectives: [...prev.objectives, ""] }));
  const removeObjective = (index) => setFormData(prev => ({ ...prev, objectives: prev.objectives.filter((_, i) => i !== index) }));

  const handleIndicatorChange = (index, field, value) => {
    const newIndicators = [...formData.indicators];
    newIndicators[index][field] = value;
    setFormData(prev => ({ ...prev, indicators: newIndicators }));
  };
  const addIndicator = () => setFormData(prev => ({ ...prev, indicators: [...prev.indicators, { description: "", target: "" }] }));
  const removeIndicator = (index) => setFormData(prev => ({ ...prev, indicators: prev.indicators.filter((_, i) => i !== index) }));

  const handleActivityChange = (index, field, value) => {
    const newActivities = [...formData.activities];
    newActivities[index][field] = value;
    setFormData(prev => ({ ...prev, activities: newActivities }));
  };
  const addActivity = () => setFormData(prev => ({ 
    ...prev, 
    activities: [...prev.activities, { phase: "", description: "", period: "", persons: "", outputs: "", budgetAmount: "", budgetSource: "" }] 
  }));
  const removeActivity = (index) => setFormData(prev => ({ ...prev, activities: prev.activities.filter((_, i) => i !== index) }));

  const nextStep = () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
    setCurrentStep(prev => Math.min(prev + 1, totalSteps));
  };
  const prevStep = () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
    setCurrentStep(prev => Math.max(prev - 1, 1));
  };
  const printDocument = () => window.print();

  const steps = [
    { title: "Project Info", desc: "Basic details" },
    { title: "Goals", desc: "Objectives & metrics" },
    { title: "Action Plan", desc: "Activities & budget" },
    { title: "Signatories", desc: "Approvals" },
    { title: "Review", desc: "Print document" }
  ];

  // --- REUSABLE UI COMPONENTS ---
  const InputField = ({ label, icon: Icon, ...props }) => (
    <div className="flex flex-col gap-1.5 w-full">
      <label className="text-sm font-semibold text-gray-700 flex items-center gap-1.5">
        {Icon && <Icon size={16} className="text-blue-500" />} {label}
      </label>
      <input 
        className="w-full p-3 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all outline-none" 
        {...props} 
      />
    </div>
  );

  const TextAreaField = ({ label, icon: Icon, ...props }) => (
    <div className="flex flex-col gap-1.5 w-full">
      <label className="text-sm font-semibold text-gray-700 flex items-center gap-1.5">
        {Icon && <Icon size={16} className="text-blue-500" />} {label}
      </label>
      <textarea 
        className="w-full p-3 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all outline-none resize-y min-h-[80px]" 
        {...props} 
      />
    </div>
  );

  const SelectField = ({ label, icon: Icon, options, ...props }) => (
    <div className="flex flex-col gap-1.5 w-full">
      <label className="text-sm font-semibold text-gray-700 flex items-center gap-1.5">
        {Icon && <Icon size={16} className="text-blue-500" />} {label}
      </label>
      <div className="relative">
        <select 
          className="w-full p-3 pr-10 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all outline-none appearance-none cursor-pointer" 
          {...props} 
        >
          <option value="" disabled>Select an option</option>
          {options.map((opt, idx) => (
            <option key={idx} value={opt}>{opt}</option>
          ))}
        </select>
        <div className="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-gray-500">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m6 9 6 6 6-6"/></svg>
