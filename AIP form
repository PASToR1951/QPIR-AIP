  const renderStep3 = () => (
    <div className="space-y-6 animate-in fade-in slide-in-from-bottom-4 duration-500">
      <div>
        <h2 className="text-2xl font-bold text-gray-800">Step 3: Action Plan</h2>
        <p className="text-gray-500 mt-1">Break down your project into specific, actionable activities.</p>
      </div>

      <div className="space-y-6">
        {formData.activities.map((act, i) => (
          <div key={i} className="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden group">
            <div className="bg-slate-50 border-b border-gray-200 px-4 py-3 flex justify-between items-center">
              <div className="flex items-center gap-2 font-bold text-gray-700">
                <div className="bg-blue-100 text-blue-700 w-6 h-6 rounded-full flex items-center justify-center text-xs">
                  {i + 1}
                </div>
                Activity Details
              </div>
              <button onClick={() => removeActivity(i)} className="text-red-500 flex items-center gap-1 text-sm font-semibold hover:bg-red-50 px-2 py-1 rounded transition-colors">
                <Trash2 size={16} /> Remove
              </button>
            </div>
            
            <div className="p-5 space-y-5">
              <div className="grid grid-cols-1 md:grid-cols-2 gap-5">
                <InputField label="Phase / Category" icon={ListTodo} value={act.phase} onChange={(e) => handleActivityChange(i, 'phase', e.target.value)} placeholder="e.g. Pre-Implementation" />
                <InputField label="Implementation Period" icon={Calendar} value={act.period} onChange={(e) => handleActivityChange(i, 'period', e.target.value)} placeholder="e.g. Jan - Mar 2026" />
              </div>

              <TextAreaField label="Activity Description" value={act.description} onChange={(e) => handleActivityChange(i, 'description', e.target.value)} placeholder="What exactly will be done?" />

              <div className="grid grid-cols-1 md:grid-cols-2 gap-5">
                <TextAreaField label="Persons Involved" icon={Users} value={act.persons} onChange={(e) => handleActivityChange(i, 'persons', e.target.value)} placeholder="e.g. School Heads, Teachers" />
                <TextAreaField label="Expected Outputs" icon={FileText} value={act.outputs} onChange={(e) => handleActivityChange(i, 'outputs', e.target.value)} placeholder="e.g. Attendance Sheets" />
              </div>

              <div className="bg-blue-50/50 p-4 rounded-lg border border-blue-100 mt-2">
                <h4 className="text-sm font-bold text-blue-800 mb-3 flex items-center gap-1.5"><DollarSign size={16} /> Budgetary Requirements</h4>
                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <InputField label="Amount" value={act.budgetAmount} onChange={(e) => handleActivityChange(i, 'budgetAmount', e.target.value)} placeholder="₱0.00 or leave blank" />
                  <InputField label="Source of Funds" value={act.budgetSource} onChange={(e) => handleActivityChange(i, 'budgetSource', e.target.value)} placeholder="e.g. MOOE" />
                </div>
              </div>
            </div>
          </div>
        ))}
        
        <button onClick={addActivity} className="w-full py-5 border-2 border-dashed border-blue-300 rounded-xl text-blue-600 font-bold hover:bg-blue-50 hover:border-blue-500 transition-all flex items-center justify-center gap-2 text-lg shadow-sm">
          <Plus size={24} /> Add New Activity
        </button>
      </div>
    </div>
  );

  const renderStep4 = () => (
    <div className="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500">
      <div>
        <h2 className="text-2xl font-bold text-gray-800">Step 4: Signatories</h2>
        <p className="text-gray-500 mt-1">Specify who is preparing and approving this implementation plan.</p>
      </div>
      
      <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div className="bg-white p-6 rounded-xl border border-gray-200 shadow-sm relative overflow-hidden">
          <div className="absolute top-0 left-0 w-1 h-full bg-blue-500"></div>
          <h3 className="font-bold text-gray-800 mb-5 flex items-center gap-2 text-lg">
            <User className="text-blue-500" /> Prepared By
          </h3>
          <div className="space-y-4">
            <InputField label="Full Name" name="preparedByName" value={formData.preparedByName} onChange={handleTextChange} placeholder="e.g. JUAN DELA CRUZ" />
            <InputField label="Title / Position" name="preparedByTitle" value={formData.preparedByTitle} onChange={handleTextChange} placeholder="e.g. Master Teacher I" />
          </div>
        </div>

        <div className="bg-white p-6 rounded-xl border border-gray-200 shadow-sm relative overflow-hidden">
          <div className="absolute top-0 left-0 w-1 h-full bg-green-500"></div>
          <h3 className="font-bold text-gray-800 mb-5 flex items-center gap-2 text-lg">
