          <button onClick={addIndicator} className="w-full py-4 border-2 border-dashed border-gray-300 rounded-lg text-gray-500 font-semibold hover:border-blue-500 hover:text-blue-600 hover:bg-blue-50 transition-all flex items-center justify-center gap-2">
            <Plus size={20} /> Add Another Indicator
          </button>
        </div>
      </div>
