          </h3>
          <div className="space-y-4">
            <InputField label="Full Name" name="approvedByName" value={formData.approvedByName} onChange={handleTextChange} placeholder="e.g. MARIA CLARA" />
            <InputField label="Title / Position" name="approvedByTitle" value={formData.approvedByTitle} onChange={handleTextChange} placeholder="e.g. School Principal I" />
