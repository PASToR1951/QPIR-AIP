      <div className="bg-blue-600 rounded-xl p-6 mb-8 text-white flex flex-col md:flex-row justify-between items-center shadow-lg print:hidden gap-4">
        <div>
          <h2 className="text-2xl font-bold flex items-center gap-2"><CheckCircle2 /> Document Ready</h2>
          <p className="text-blue-100 mt-1">Review your generated plan below. You can click on any text in the document to make final live edits before printing.</p>
