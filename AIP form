        <button onClick={printDocument} className="flex items-center gap-2 bg-white text-blue-700 px-6 py-3 rounded-lg font-bold hover:bg-blue-50 transition-colors shadow-sm whitespace-nowrap">
          <Printer size={20} /> Print / Save PDF
        </button>
      </div>

      <div className="max-w-[1000px] mx-auto bg-[#fffcf0] border border-gray-300 shadow-xl p-8 print:shadow-none print:border-none print:p-0 print:max-w-none print:bg-white text-sm">
