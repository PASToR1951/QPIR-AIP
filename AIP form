                    <textarea rows={3} value={act.period} onChange={(e) => handleActivityChange(index, 'period', e.target.value)} className="w-full h-full text-center resize-none bg-transparent focus:outline-none focus:ring-1 focus:ring-blue-300" />
                  </td>
                  <td className="border-r border-black p-2 align-top text-center">
                    <textarea rows={3} value={act.persons} onChange={(e) => handleActivityChange(index, 'persons', e.target.value)} className="w-full h-full text-center resize-none bg-transparent focus:outline-none focus:ring-1 focus:ring-blue-300" />
                  </td>
                  <td className="border-r border-black p-2 align-top">
                     <textarea rows={3} value={act.outputs} onChange={(e) => handleActivityChange(index, 'outputs', e.target.value)} className="w-full h-full resize-none bg-transparent focus:outline-none focus:ring-1 focus:ring-blue-300" />
                  </td>
                  <td className="border-r border-black p-2 align-top w-24">
                     <textarea rows={3} value={act.budgetAmount} onChange={(e) => handleActivityChange(index, 'budgetAmount', e.target.value)} className="w-full h-full text-right resize-none bg-transparent focus:outline-none focus:ring-1 focus:ring-blue-300" />
                  </td>
                  <td className="p-2 align-top w-24">
                     <textarea rows={3} value={act.budgetSource} onChange={(e) => handleActivityChange(index, 'budgetSource', e.target.value)} className="w-full h-full text-center resize-none bg-transparent focus:outline-none focus:ring-1 focus:ring-blue-300" />
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div className="flex justify-between mt-12 mb-8 px-4">
          <div className="w-1/3">
            <div className="text-sm mb-6">Prepared by:</div>
            <div className="flex flex-col">
              <input type="text" name="preparedByName" value={formData.preparedByName} onChange={handleTextChange} className="font-bold text-center bg-transparent border-b border-black focus:outline-none focus:border-blue-500 print:border-black uppercase" />
              <input type="text" name="preparedByTitle" value={formData.preparedByTitle} onChange={handleTextChange} className="text-center text-sm bg-transparent border-b border-transparent hover:border-gray-300 focus:outline-none focus:border-blue-500 print:border-transparent" />
            </div>
          </div>
          <div className="w-1/3">
            <div className="text-sm mb-6 flex items-center justify-center">Approved:</div>
            <div className="flex flex-col">
              <input type="text" name="approvedByName" value={formData.approvedByName} onChange={handleTextChange} className="font-bold text-center bg-transparent border-b border-black focus:outline-none focus:border-blue-500 print:border-black uppercase" />
              <input type="text" name="approvedByTitle" value={formData.approvedByTitle} onChange={handleTextChange} className="text-center text-sm bg-transparent border-b border-transparent hover:border-gray-300 focus:outline-none focus:border-blue-500 print:border-transparent" />
            </div>
          </div>
        </div>
      </div>
    </div>
  );

  return (
    <div className="min-h-screen bg-slate-100 font-sans print:bg-white flex flex-col relative pb-24 print:pb-0">
      
      {/* Top Navbar / Progress Header */}
      <div className="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-50 print:hidden">
        <div className="max-w-5xl mx-auto px-4 py-4">
          <div className="hidden md:flex items-center justify-between relative">
            {/* Progress Line Background */}
            <div className="absolute left-[5%] right-[5%] top-4 h-1 bg-gray-100 -z-10 rounded"></div>
            {/* Active Progress Line */}
            <div 
              className="absolute left-[5%] top-4 h-1 bg-blue-600 -z-10 rounded transition-all duration-500 ease-out" 
              style={{ width: `${((currentStep - 1) / (totalSteps - 1)) * 90}%` }}
            ></div>

            {/* Step Indicators */}
            {steps.map((step, index) => {
              const stepNum = index + 1;
              const isActive = stepNum === currentStep;
              const isCompleted = stepNum < currentStep;

              return (
                <div key={stepNum} className="flex flex-col items-center group cursor-pointer w-32" onClick={() => {window.scrollTo({top:0}); setCurrentStep(stepNum);}}>
                  <div className={`w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold border-[3px] transition-all duration-300 bg-white ${
                    isActive ? 'border-blue-600 text-blue-600 scale-110 shadow-md' : 
                    isCompleted ? 'border-blue-600 bg-blue-600 text-white' : 
                    'border-gray-200 text-gray-400'
                  }`}>
                    {isCompleted ? <CheckCircle2 size={18} /> : stepNum}
                  </div>
                  <span className={`text-sm mt-2 font-bold transition-colors ${isActive ? 'text-gray-900' : isCompleted ? 'text-gray-700' : 'text-gray-400'}`}>
                    {step.title}
                  </span>
                  <span className={`text-xs text-center transition-colors ${isActive ? 'text-blue-600 font-medium' : 'text-gray-400'}`}>
                    {step.desc}
                  </span>
                </div>
              );
            })}
          </div>
          
          {/* Mobile Progress View */}
          <div className="md:hidden flex items-center justify-between">
            <div>
              <span className="text-xs text-blue-600 font-bold uppercase tracking-wider">Step {currentStep} of {totalSteps}</span>
              <h2 className="text-lg font-bold text-gray-900">{steps[currentStep - 1].title}</h2>
            </div>
            <div className="w-12 h-12 rounded-full border-4 border-gray-100 flex items-center justify-center relative">
               <svg className="absolute top-0 left-0 w-full h-full transform -rotate-90">
                <circle cx="24" cy="24" r="22" stroke="currentColor" strokeWidth="4" fill="transparent" className="text-gray-100" />
                <circle cx="24" cy="24" r="22" stroke="currentColor" strokeWidth="4" fill="transparent" strokeDasharray={22 * 2 * Math.PI} strokeDashoffset={(22 * 2 * Math.PI) - (((currentStep) / totalSteps) * (22 * 2 * Math.PI))} className="text-blue-600 transition-all duration-500" />
              </svg>
              <span className="text-sm font-bold text-gray-700">{Math.round((currentStep/totalSteps)*100)}%</span>
            </div>
          </div>
        </div>
      </div>

      {/* Main Content Area */}
      <div className="flex-grow p-4 md:p-8 pt-8 print:p-0">
        <div className="max-w-4xl mx-auto print:max-w-none">
          {currentStep === 1 && renderStep1()}
          {currentStep === 2 && renderStep2()}
          {currentStep === 3 && renderStep3()}
          {currentStep === 4 && renderStep4()}
          {currentStep === 5 && renderPreview()}
        </div>
      </div>

      {/* Sticky Bottom Navigation Footer */}
      <div className="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 p-4 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)] z-40 print:hidden">
        <div className="max-w-4xl mx-auto flex justify-between items-center">
          <button 
            onClick={prevStep} 
            disabled={currentStep === 1}
            className={`flex items-center gap-2 px-5 py-3 rounded-lg font-bold transition-all ${currentStep === 1 ? 'opacity-0 pointer-events-none' : 'text-gray-600 bg-white border-2 border-gray-200 hover:bg-gray-50 hover:border-gray-300'}`}
          >
            <ArrowLeft size={20} /> Back
          </button>

          {currentStep < totalSteps ? (
            <button 
              onClick={nextStep} 
              className="flex items-center gap-2 px-8 py-3 bg-blue-600 text-white rounded-lg font-bold hover:bg-blue-700 transition-colors shadow-lg shadow-blue-500/30"
            >
              Next Step <ArrowRight size={20} />
            </button>
          ) : (
            <button 
              onClick={() => setCurrentStep(1)} 
              className="flex items-center gap-2 px-8 py-3 bg-gray-800 text-white rounded-lg font-bold hover:bg-gray-900 transition-colors shadow-lg"
            >
              <Edit3 size={20} /> Edit Details
            </button>
          )}
        </div>
      </div>

    </div>
  );
}
