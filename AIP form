            <textarea rows={2} name="outcome" value={formData.outcome} onChange={handleTextChange} className="w-full bg-transparent border-b border-transparent hover:border-gray-300 focus:border-blue-500 focus:outline-none italic text-blue-900 print:text-black print:border-none resize-none align-top" />
