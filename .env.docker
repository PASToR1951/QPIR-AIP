# =============================================================================
# AIP-PIR Docker Environment — copy to .env and fill in values
#   cp .env.docker .env
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=pir_system

# ── Backend ───────────────────────────────────────────────────────────────────
# Use a long random string. Generate one with:  openssl rand -hex 64
JWT_SECRET=change_me_very_long_random_secret_key

# Used to encrypt SMTP credentials stored by the app. Keep this stable after
# production launch or existing saved SMTP passwords cannot be decrypted.
# Generate with:  openssl rand -hex 64
EMAIL_CONFIG_SECRET=change_me_email_config_secret

# Browser origin allowed to call the API.
# Examples:
#   http://localhost
#   http://192.168.1.100
#   https://yourdomain.com
ALLOWED_ORIGIN=http://localhost

# ── Frontend ──────────────────────────────────────────────────────────────────
# The URL that browsers (client machines) use to reach the backend API.
# This is baked into the React build — change it and rebuild if the host changes.
#
# Examples:
#   http://192.168.1.100:3001     (local network IP)
#   https://api.yourdomain.com    (domain with reverse proxy)
#   http://localhost:3001         (same machine only)
VITE_API_URL=http://localhost:3001

# Port the frontend is served on (default 80)
# FRONTEND_PORT=80

# ── reCAPTCHA v3 ──────────────────────────────────────────────────────────────
# Leave blank to disable reCAPTCHA.
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── OAuth SSO ─────────────────────────────────────────────────────────────────
# Leave blank to disable Google sign-in.

# Google Workspace
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Shared OAuth config
# Random secret for HMAC-signing OAuth state params — generate with:
#   openssl rand -hex 64
OAUTH_STATE_SECRET=
# Base URL of this backend server (used to build the IdP callback redirect_uri)
#   Dev:  http://localhost:3001
#   Prod: https://api.yourdomain.deped.gov.ph  (or whatever your backend is served on)
OAUTH_REDIRECT_BASE_URL=http://localhost:3001

# ── Backup ────────────────────────────────────────────────────────────────────
# AES-256-CBC encryption key for backup files.
# Generate with:  openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32

# Read-only PostgreSQL user for pg_dump (created via server/scripts/db_readonly_user.sql)
BACKUP_DB_USER=backup_reader
BACKUP_DB_PASSWORD=change_me_backup_reader_password

# Number of days to retain local backups
BACKUP_RETENTION_DAYS=5

# Set to true to enable rclone cloud sync (requires rclone configured on host)
BACKUP_CLOUD_ENABLED=false

# rclone remote name (from `rclone config`) and destination path
BACKUP_RCLONE_REMOTE=my_remote
BACKUP_RCLONE_PATH=/QPIR-AIP-Backups

# Host path to rclone config directory (mounted into backup container read-only)
# RCLONE_CONFIG_DIR=~/.config/rclone

# ── Claude DevTools ───────────────────────────────────────────────────────────
# Path to the .claude directory on the host machine
# CLAUDE_DIR=~/.claude
