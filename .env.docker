# =============================================================================
# AIP-PIR Docker Environment — copy to .env and fill in values
#   cp .env.docker .env
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=pir_system

# ── Backend ───────────────────────────────────────────────────────────────────
# Use a long random string. Generate one with:  openssl rand -hex 64
JWT_SECRET=change_me_very_long_random_secret_key

# ── Frontend ──────────────────────────────────────────────────────────────────
# The URL that browsers (client machines) use to reach the backend API.
# This is baked into the React build — change it and rebuild if the host changes.
#
# Examples:
#   http://192.168.1.100:3001     (local network IP)
#   https://api.yourdomain.com    (domain with reverse proxy)
#   http://localhost:3001         (same machine only)
VITE_API_URL=http://localhost:3001

# Port the frontend is served on (default 80)
# FRONTEND_PORT=80

# ── OAuth SSO ─────────────────────────────────────────────────────────────────
# Leave blank to disable the corresponding provider.

# Microsoft Entra ID (M365)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# DepEd's specific Azure tenant ID — use the tenant GUID, NOT "common"
MICROSOFT_TENANT_ID=

# Google Workspace
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Shared OAuth config
# Random secret for HMAC-signing OAuth state params — generate with:
#   openssl rand -hex 64
OAUTH_STATE_SECRET=
# Base URL of this backend server (used to build the IdP callback redirect_uri)
#   Dev:  http://localhost:3001
#   Prod: https://api.yourdomain.deped.gov.ph  (or whatever your backend is served on)
OAUTH_REDIRECT_BASE_URL=http://localhost:3001

# ── Claude DevTools ───────────────────────────────────────────────────────────
# Path to the .claude directory on the host machine
# CLAUDE_DIR=~/.claude
